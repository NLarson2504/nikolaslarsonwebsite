# Firebase web config. These values are public by design (they ship in the
# browser bundle) — access is controlled by Firestore security rules, not by
# hiding these keys. Copy this file to .env.local and fill in your project's
# values from the Firebase console (Project settings > Your apps > Web app).
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=
